<Window x:Class="FLARE.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About FLARE"
        Width="420" Height="500" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Background="{DynamicResource DarkBackgroundBrush}"
        Foreground="{DynamicResource FlareBodyText}"
        Icon="/Logo/flare_icon.ico">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header panel: 3D logo + title -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}" Padding="24,20,24,16"
                BorderBrush="{DynamicResource FlareHairline}" BorderThickness="0,0,0,1">
            <StackPanel>
                <Viewport3D x:Name="LogoViewport" Height="140" ClipToBounds="True">
                    <Viewport3D.Camera>
                        <PerspectiveCamera Position="0,0,4.5" LookDirection="0,0,-1" UpDirection="0,1,0" FieldOfView="45"/>
                    </Viewport3D.Camera>
                    <ModelVisual3D>
                        <ModelVisual3D.Content>
                            <Model3DGroup>
                                <AmbientLight Color="#404040"/>
                                <DirectionalLight Color="#BBBBBB" Direction="-0.3,-0.3,-1"/>
                                <DirectionalLight Color="#666666" Direction="0.3,0.2,1"/>
                            </Model3DGroup>
                        </ModelVisual3D.Content>
                    </ModelVisual3D>
                    <ModelVisual3D x:Name="BoxModel">
                        <ModelVisual3D.Transform>
                            <RotateTransform3D>
                                <RotateTransform3D.Rotation>
                                    <AxisAngleRotation3D x:Name="BoxRotation" Axis="0,1,0" Angle="0"/>
                                </RotateTransform3D.Rotation>
                            </RotateTransform3D>
                        </ModelVisual3D.Transform>
                    </ModelVisual3D>
                </Viewport3D>

                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="FLARE" FontSize="24" FontWeight="Bold"
                               Foreground="{DynamicResource FlareStrongText}"/>
                    <TextBlock Text="Fault Log Analysis &amp; Reboot Examination" FontSize="11"
                               Foreground="{DynamicResource FlareMutedText}" Margin="0,2,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Content -->
        <StackPanel Grid.Row="1" Margin="24,16,24,16">
            <StackPanel>
                <TextBlock x:Name="VersionText" FontSize="12"
                           Foreground="{DynamicResource FlareBodyText}"/>
                <TextBlock x:Name="RuntimeText" FontSize="11"
                           Foreground="{DynamicResource FlareMutedText}" Margin="0,2,0,0"/>
            </StackPanel>

            <StackPanel Margin="0,12,0,0">
                <TextBlock Text="Daniel Naslund (@deezel)" FontSize="11"
                           Foreground="{DynamicResource FlareMutedText}"/>
                <TextBlock FontSize="11"
                           Foreground="{DynamicResource FlareLabelText}" Margin="0,8,0,0"
                           Text="Vortice.Vulkan  ·  CommunityToolkit.Mvvm  ·  WPF"/>
            </StackPanel>

            <TextBlock TextWrapping="Wrap" FontSize="11"
                       Foreground="{DynamicResource FlareLabelText}" Margin="0,12,0,0"
                       Text="NVIDIA GPU diagnostics tool. Collects and correlates data from Windows Event Log, kernel crash dumps, and nvidia-smi."/>
        </StackPanel>

        <!-- Footer panel: Close button -->
        <Border Grid.Row="2" Background="{DynamicResource AccentBrush}" Padding="24,12"
                BorderBrush="{DynamicResource FlareHairline}" BorderThickness="0,1,0,0">
            <Button Content="Close" HorizontalAlignment="Right"
                    Padding="20,6" MinWidth="80" IsCancel="True" Click="CloseClick"/>
        </Border>
    </Grid>
</Window>
