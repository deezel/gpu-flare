<Window x:Class="FLARE.UI.Views.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About FLARE"
        Width="420" Height="500" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        Icon="/Logo/flare_icon.ico">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="140"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 3D Logo -->
        <Viewport3D Grid.Row="0" x:Name="LogoViewport" ClipToBounds="True">
            <Viewport3D.Camera>
                <PerspectiveCamera Position="0,0,4.5" LookDirection="0,0,-1" UpDirection="0,1,0" FieldOfView="45"/>
            </Viewport3D.Camera>
            <ModelVisual3D>
                <ModelVisual3D.Content>
                    <Model3DGroup>
                        <AmbientLight Color="#404040"/>
                        <DirectionalLight Color="#BBBBBB" Direction="-0.3,-0.3,-1"/>
                        <DirectionalLight Color="#666666" Direction="0.3,0.2,1"/>
                    </Model3DGroup>
                </ModelVisual3D.Content>
            </ModelVisual3D>
            <ModelVisual3D x:Name="BoxModel">
                <ModelVisual3D.Transform>
                    <RotateTransform3D>
                        <RotateTransform3D.Rotation>
                            <AxisAngleRotation3D x:Name="BoxRotation" Axis="0,1,0" Angle="0"/>
                        </RotateTransform3D.Rotation>
                    </RotateTransform3D>
                </ModelVisual3D.Transform>
            </ModelVisual3D>
        </Viewport3D>

        <!-- Title -->
        <StackPanel Grid.Row="1" Margin="0,8,0,0">
            <TextBlock Text="FLARE" FontSize="24" FontWeight="Bold"/>
            <TextBlock Text="Fault Log Analysis &amp; Reboot Examination" FontSize="11"
                       Foreground="#999999" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Version Info -->
        <StackPanel Grid.Row="2" Margin="0,12,0,0">
            <TextBlock x:Name="VersionText" FontSize="12" Foreground="#BBBBBB"/>
            <TextBlock x:Name="RuntimeText" FontSize="11" Foreground="#999999" Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Author / Deps -->
        <StackPanel Grid.Row="3" Margin="0,12,0,0">
            <TextBlock Text="Daniel Naslund (@deezel)" FontSize="11" Foreground="#999999"/>
            <TextBlock FontSize="11" Foreground="#707070" Margin="0,8,0,0"
                       Text="Vortice.Vulkan  ·  CommunityToolkit.Mvvm  ·  WPF"/>
        </StackPanel>

        <!-- Description -->
        <TextBlock Grid.Row="4" TextWrapping="Wrap" FontSize="11" Foreground="#707070" Margin="0,12,0,0"
                   Text="NVIDIA GPU diagnostics tool. Collects and correlates data from Windows Event Log, kernel crash dumps, and nvidia-smi."/>

        <!-- Close -->
        <Button Grid.Row="5" Content="Close" HorizontalAlignment="Right"
                Padding="20,6" MinWidth="80" IsCancel="True" Click="CloseClick"/>
    </Grid>
</Window>
