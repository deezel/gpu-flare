<Window x:Class="FLARE.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:FLARE.UI.ViewModels"
        xmlns:converters="clr-namespace:FLARE.UI.Converters"
        Title="FLARE - Fault Log Analysis &amp; Reboot Examination"
        Height="700" Width="900"
        MinHeight="500" MinWidth="700"
        WindowStartupLocation="CenterScreen"
        Icon="Logo/flare_icon.ico">
    <Window.Resources>
        <converters:BoolToOpacityConverter x:Key="BoolToOpacityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Settings -->
        <Border Grid.Row="0" Background="{DynamicResource AccentBrush}"
                Padding="20,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Report Output Path -->
                <Grid Grid.Row="0" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Report Output:"/>
                    <TextBox Grid.Column="1" Text="{Binding OutputPath, UpdateSourceTrigger=PropertyChanged}"
                             Margin="0,0,10,0"/>
                    <Button Grid.Column="2" Content="Browse..." Command="{Binding BrowseOutputCommand}"
                            Padding="15,5" MinWidth="80"/>
                </Grid>

                <!-- Numeric Settings Row -->
                <Grid Grid.Row="1" Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" MinWidth="130"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Label Grid.Column="0" Content="Max Days:"/>
                    <TextBox Grid.Column="1" Text="{Binding MaxDays, UpdateSourceTrigger=PropertyChanged}"
                             Width="80" Margin="0,0,20,0"/>
                    <Label Grid.Column="2" Content="Max Events:"/>
                    <TextBox Grid.Column="3" Text="{Binding MaxEvents, UpdateSourceTrigger=PropertyChanged}"
                             Width="80"/>
                    <CheckBox Grid.Column="5" Content="Newest first"
                              IsChecked="{Binding SortDescending}"
                              VerticalAlignment="Center"
                              ToolTip="Order all date-based report sections with the newest entry first. Uncheck for chronological (oldest first)."/>
                </Grid>

                <!-- Deep Analyze -->
                <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                    <CheckBox Content="Deep analysis (WinDbg)"
                              IsChecked="{Binding DeepAnalyze}"
                              IsEnabled="{Binding CdbFound}"
                              VerticalAlignment="Center"
                              Opacity="{Binding CdbFound, Converter={StaticResource BoolToOpacityConverter}}"
                              ToolTip="Runs cdb.exe !analyze -v on each dump file. Up to 30 seconds per dump — with many dumps this can take several minutes. Safe to cancel mid-run."/>
                    <TextBlock Text="{Binding CdbStatusText}" Foreground="#999999"
                               FontSize="11" Margin="12,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="(slow: ~30s per dump)" Foreground="#707070"
                               FontSize="10" Margin="8,0,0,0" VerticalAlignment="Center"
                               Visibility="{Binding CdbFound, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                </StackPanel>

                <!-- Run Button -->
                <Grid Grid.Row="3">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="Run Analysis" Command="{Binding RunCommand}"
                            Style="{StaticResource AccentButton}"
                            Padding="20,8" FontSize="14" FontWeight="Bold" MinWidth="150"/>
                    <Button Grid.Column="1" Content="Cancel" Command="{Binding CancelCommand}"
                            Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Padding="10,8" FontSize="12" MinWidth="80" Margin="10,0,0,0"
                            VerticalAlignment="Center"/>
                    <ProgressBar Grid.Column="2" IsIndeterminate="{Binding IsRunning}"
                                 Visibility="{Binding IsRunning, Converter={StaticResource BooleanToVisibilityConverter}}"
                                 Width="120" Height="4" Margin="15,0,0,0" VerticalAlignment="Center"
                                 Foreground="{DynamicResource ButtonAccentBrush}"/>
                    <TextBlock Text="{Binding StatusText}" Grid.Column="3" Foreground="#999999"
                               FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Log Output -->
        <TextBox Grid.Row="1"
                 Text="{Binding LogOutput, Mode=OneWay}"
                 IsReadOnly="True"
                 IsReadOnlyCaretVisible="True"
                 IsTabStop="True"
                 Focusable="True"
                 VerticalScrollBarVisibility="Auto"
                 HorizontalScrollBarVisibility="Auto"
                 FontFamily="Consolas" FontSize="12"
                 Background="#282830" BorderThickness="0" Padding="15,10"
                 TextWrapping="NoWrap"
                 x:Name="LogTextBox"/>

        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{DynamicResource AccentBrush}"
                Padding="10,4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="{Binding BottomStatusText}" Foreground="#999999" FontSize="11"/>
                <TextBlock Grid.Column="1" Text="{Binding ElevationText}" Foreground="#999999" FontSize="11"
                           Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2" Text="About" Foreground="#BBBBBB" FontSize="11"
                           Cursor="Hand" MouseLeftButtonUp="AboutClick"
                           TextDecorations="Underline"/>
            </Grid>
        </Border>
    </Grid>
</Window>
